{
  "version": "1.0.0",
  "tasks": {
    "docs:build": "deno run --allow-read --allow-write --allow-env --allow-net scripts/build-docs.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@deno/gfm": "jsr:@deno/gfm@^0.11.0"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  },
  "exclude": [
    "docs-dist/"
  ]
}
